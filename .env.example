# ── Runtime ───────────────────────────────────────────────────────────────────

# Path to the mailbox_server.proto file
PROTO_PATH=./protos/mailbox_server.proto

# SQLite file for checkpoints and device registrations
CHECKPOINT_DB=./relay.db

# Delay in ms before reconnecting after a stream error or disconnect
SUBSCRIBE_RETRY_MS=3000

# HTTP port for /healthz, /metrics, and /v1/* endpoints
METRICS_PORT=9898

# Set to 1 to process messages without actually sending APNs notifications
DRY_RUN=0

# ── APNs credentials ──────────────────────────────────────────────────────────
APNS_KEY_FILE=./keys/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_TOPIC=com.example.yourapp

# Set to 1 for production app builds; 0 for development/sandbox builds
APNS_PRODUCTION=1

APNS_PUSH_TYPE=alert

# ── HTTP API ──────────────────────────────────────────────────────────────────

# API token required on all /v1/* endpoints
# Generate with: openssl rand -hex 32
RELAY_API_TOKEN=

# Rate limiting for /v1/* endpoints (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Set to 1 if running behind a reverse proxy (nginx, etc.)
TRUST_PROXY=0
